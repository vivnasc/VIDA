{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "paths": {
      "@vida/ui": ["./packages/ui/src"],
      "@vida/ui/*": ["./packages/ui/src/*"],
      "@vida/auth": ["./packages/auth/src"],
      "@vida/auth/*": ["./packages/auth/src/*"],
      "@vida/database": ["./packages/database/src"],
      "@vida/database/*": ["./packages/database/src/*"],
      "@vida/utils": ["./packages/utils/src"],
      "@vida/utils/*": ["./packages/utils/src/*"],
      "@vida/config": ["./packages/config/src"],
      "@vida/config/*": ["./packages/config/src/*"]
    }
  },
  "exclude": ["node_modules"]
}

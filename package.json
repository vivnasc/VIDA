{
  "name": "vida-ecosystem",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "dev:familia": "turbo dev --filter=@vida/familia",
    "dev:dinheiro": "turbo dev --filter=@vida/dinheiro",
    "dev:lar": "turbo dev --filter=@vida/lar",
    "dev:saude": "turbo dev --filter=@vida/saude",
    "build:familia": "turbo build --filter=@vida/familia",
    "build:dinheiro": "turbo build --filter=@vida/dinheiro",
    "build:lar": "turbo build --filter=@vida/lar",
    "build:saude": "turbo build --filter=@vida/saude",
    "dev:biz": "turbo dev --filter=@vida/biz",
    "build:biz": "turbo build --filter=@vida/biz",
    "db:migrate": "supabase db push",
    "db:seed": "supabase db seed",
    "db:reset": "supabase db reset"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.9.4"
}
